/* detail.wxss —— 详情页样式 */
.page {
  padding: 32rpx;
  background: #f5f6f8;
  min-height: 100vh;
  box-sizing: border-box;
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #222;
}
.tip {
  margin: 12rpx 0 32rpx;
  font-size: 24rpx;
  color: #999;
}
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 40rpx;
}
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 30rpx;
}
.row:last-child {
  border-bottom: none;
}
.label {
  color: #999;
}
.value {
  color: #333;
  font-weight: 500;
}
.btn {
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
}
