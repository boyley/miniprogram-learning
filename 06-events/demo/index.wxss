/* 06 事件系统 demo 样式 */
.page {
  padding: 24rpx;
  background: #f5f6f8;
  min-height: 100vh;
  box-sizing: border-box;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 8rpx;
}

.tip {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

/* 1. 冒泡示例 */
.outer {
  background: #eef2ff;
  border: 2rpx dashed #6366f1;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 26rpx;
  color: #4338ca;
  text-align: center;
}

.inner {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #fff;
}

.inner.bind {
  background: #22c55e;
}

.inner.catch {
  background: #ef4444;
}

/* 列表行 */
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
  font-size: 28rpx;
  color: #333;
}

.row:active {
  background: #f7f7f9;
}

.row-id {
  font-size: 24rpx;
  color: #999;
}

/* 输入框 */
.input {
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
}

/* target/currentTarget 盒子 */
.tc-box {
  background: #fff7ed;
  border: 2rpx solid #fb923c;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 26rpx;
  color: #9a3412;
  text-align: center;
}

.tc-child {
  display: inline-block;
  margin-top: 16rpx;
  padding: 12rpx 20rpx;
  background: #fdba74;
  border-radius: 8rpx;
  color: #7c2d12;
}

/* 结果显示 */
.result {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #f0f9ff;
  border-left: 6rpx solid #0ea5e9;
  border-radius: 6rpx;
  font-size: 26rpx;
  color: #0369a1;
  word-break: break-all;
}
