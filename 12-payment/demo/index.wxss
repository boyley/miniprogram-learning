/* 12-payment/demo/index.wxss */

.page {
  padding: 24rpx 28rpx 60rpx;
  background: #f5f6f8;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 顶部 */
.hero {
  background: linear-gradient(135deg, #07c160, #10b981);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  color: #fff;
  margin-bottom: 24rpx;
}
.hero-title { font-size: 40rpx; font-weight: 700; }
.hero-sub { font-size: 24rpx; opacity: 0.9; margin-top: 10rpx; }

/* 卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 20rpx;
}

/* 流程图 */
.flow { display: flex; flex-direction: column; }
.flow-line {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
  background: #f2f4f7;
  border-radius: 10rpx;
  padding: 14rpx 18rpx;
}
.flow-arrow {
  font-size: 24rpx;
  color: #07c160;
  text-align: center;
  margin: 6rpx 0;
}

/* 高亮 */
.hl { color: #07c160; font-weight: 600; }
.hl.danger { color: #e64340; }

/* 参数 5 件套 */
.param-tip {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
  margin-bottom: 18rpx;
}
.param {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.param:last-child { border-bottom: none; }
.param-k {
  font-size: 26rpx;
  color: #555;
  font-weight: 600;
  flex-shrink: 0;
  margin-right: 20rpx;
}
.param-v {
  font-size: 24rpx;
  color: #999;
  font-family: monospace;
  text-align: right;
  word-break: break-all;
}

/* 支付按钮 */
.pay-btn {
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  margin-top: 8rpx;
}
.pay-btn::after { border: none; }
.btn-note {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  margin: 14rpx 0 24rpx;
  line-height: 1.5;
}

/* 结果 */
.result {
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}
.result.success { background: #e8f8ef; border: 1rpx solid #07c160; }
.result.fail { background: #fdeeee; border: 1rpx solid #e64340; }
.result-title { font-size: 28rpx; font-weight: 700; color: #222; }
.result-msg {
  font-size: 25rpx;
  color: #555;
  line-height: 1.5;
  margin-top: 10rpx;
}
.result-warn {
  font-size: 24rpx;
  color: #a15a00;
  line-height: 1.5;
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx dashed #d8b878;
}

/* 提示 */
.tips {
  background: #fff8ec;
  border: 1rpx solid #ffe0a3;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
}
.tips-title { font-size: 28rpx; font-weight: 600; color: #a15a00; margin-bottom: 14rpx; }
.tip { font-size: 25rpx; color: #6b5220; line-height: 1.7; }
