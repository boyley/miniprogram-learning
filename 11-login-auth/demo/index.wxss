/* 11 登录授权 demo 样式 */
.page {
  padding: 24rpx;
  background: #f2f3f5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 登录态条 */
.status {
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}
.status.ok { background: #e7f7ec; color: #18a058; }
.status.no { background: #fdeaea; color: #d03050; }

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
  margin-bottom: 8rpx;
}
.desc {
  font-size: 24rpx;
  color: #8a9099;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

/* 结果区 */
.result {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
}
.line { font-size: 26rpx; color: #1f2329; word-break: break-all; }
.mono {
  font-family: monospace;
  color: #2b6cb0;
}
.hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #a06a00;
  background: #fff8e6;
  padding: 12rpx;
  border-radius: 8rpx;
  line-height: 1.5;
}

/* 用户信息 */
.profile {
  display: flex;
  align-items: center;
}
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #ddd;
}
.nick { font-size: 30rpx; color: #1f2329; }

.logout { margin-top: 8rpx; }
