/* 05 逻辑层与 setData —— 样式 */
.page {
  padding: 24rpx;
  background: #f2f3f5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 顶部横幅：最近操作 */
.banner {
  background: #1989fa;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
}
.banner-label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
}
.banner-value {
  color: #fff;
  font-size: 28rpx;
  margin-top: 6rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 20rpx;
}

/* 计数器 */
.counter {
  text-align: center;
  margin-bottom: 20rpx;
}
.count-num {
  font-size: 96rpx;
  font-weight: 700;
  color: #1989fa;
}

/* 按钮行 */
.btn-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}
.btn {
  margin: 0;
  background: #f2f3f5;
  color: #323233;
  border-radius: 12rpx;
}
.btn.primary {
  background: #1989fa;
  color: #fff;
}
.btn.danger {
  background: #fff1f0;
  color: #ee0a24;
  width: 100%;
}

/* 键值对 */
.kv {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f2f3f5;
}
.k {
  color: #969799;
  font-size: 26rpx;
}
.v {
  color: #323233;
  font-size: 26rpx;
  font-weight: 500;
}

/* 待办项 */
.todo {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2f3f5;
}
.todo-check {
  font-size: 32rpx;
  color: #c8c9cc;
  margin-right: 16rpx;
}
.todo-check.checked {
  color: #07c160;
}
.todo-title {
  flex: 1;
  font-size: 28rpx;
  color: #323233;
}
.todo-title.done {
  color: #c8c9cc;
  text-decoration: line-through;
}
.todo-idx {
  font-size: 22rpx;
  color: #c8c9cc;
}

/* 提示文字 */
.tip {
  font-size: 22rpx;
  color: #969799;
  margin-top: 12rpx;
  line-height: 1.5;
}
.note {
  font-size: 24rpx;
  color: #646566;
  line-height: 1.6;
  margin-top: 10rpx;
}
