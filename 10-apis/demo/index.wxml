<!-- 常用交互/设备 API 演示：每个按钮触发一个 wx.* API -->
<view class="page">
  <view class="title">常用交互 / 设备 API 演示</view>

  <!-- ① 界面交互类 API -->
  <view class="group">
    <view class="group-title">界面交互</view>
    <button class="btn" bindtap="onToast">showToast 成功提示</button>
    <button class="btn" bindtap="onModal">showModal 确认框</button>
    <button class="btn" bindtap="onLoading">showLoading / hideLoading</button>
    <button class="btn" bindtap="onActionSheet">showActionSheet 底部菜单</button>
  </view>

  <!-- ② 剪贴板 / 系统信息 -->
  <view class="group">
    <view class="group-title">剪贴板 / 系统信息</view>
    <button class="btn" bindtap="onCopy">setClipboardData 复制文本</button>
    <button class="btn" bindtap="onSystemInfo">getSystemInfoSync 机型信息</button>
  </view>

  <!-- ③ 设备能力（部分真机才有效） -->
  <view class="group">
    <view class="group-title">设备能力（部分需真机）</view>
    <button class="btn" bindtap="onPhone">makePhoneCall 拨号</button>
    <button class="btn" bindtap="onScan">scanCode 扫码</button>
    <button class="btn" bindtap="onPreview">previewImage 预览图片</button>
  </view>

  <!-- 结果展示区：各 API 回调里 setData 把结果写到这里 -->
  <view class="result-box">
    <view class="result-title">最近一次结果</view>
    <view class="result-text">{{result || '（点上面的按钮试试）'}}</view>
  </view>
</view>
