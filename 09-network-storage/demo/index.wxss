/* 09 网络与存储 demo 样式 */
.page {
  padding: 24rpx;
  background: #f4f5f7;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.tip {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.code {
  color: #d14;
  font-family: monospace;
}

/* 输入框 */
.input {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

/* 按钮 */
.btn {
  margin: 0;
}

.btn.primary {
  background: #07c160;
  color: #fff;
}

.btn.danger {
  background: #fa5151;
  color: #fff;
}

.btn-row {
  display: flex;
  gap: 16rpx;
}

.btn-row .btn {
  flex: 1;
}

/* 结果展示 */
.result {
  margin-top: 20rpx;
  background: #f7f8fa;
  border-radius: 10rpx;
  padding: 20rpx;
}

.result-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.result-text {
  font-size: 26rpx;
  color: #333;
  word-break: break-all;
  white-space: pre-wrap;
}
